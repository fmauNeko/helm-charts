# Enforce LF line endings for all text files
* text=auto eol=lf

# Explicit overrides
*.sh text eol=lf
*.tpl text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.toml text eol=lf

# Binary files: no conversion
*.png binary
*.jpg binary
*.ico binary
*.tgz binary
*.gz binary
*.zip binary
*.woff binary
*.woff2 binary
